{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Construction AI Estimator",
  "version": "1.0.0",
  "identifier": "com.constructionai.estimator",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Construction AI Estimator",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/python-sidecar"],
    "resources": ["../prompts/**/*", "../config/**/*", "../models/**/*"]
  },
  "plugins": {}
}
